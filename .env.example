# Copy to `.env` and fill in. `.env` is git-ignored; this template is committed.

# ── Supabase ─────────────────────────────────────────────────────────────────
# Local dev: run `supabase start` and paste the API URL + keys it prints (API
#   http://127.0.0.1:54321, emails caught at http://127.0.0.1:54324).
# Hosted: Dashboard → Project → Settings → API.
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key

# The Next.js web app (M2) reads the public-prefixed copies in the browser.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# The extension (Vite) bakes these into its bundle at build time.
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only — NEVER expose to the browser or extension. Used by Next.js route
# handlers for the AI proxy and BYOK key decryption. (M5)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Symmetric secret pgcrypto uses to encrypt BYOK provider API keys at rest. (M5)
# Generate one, e.g.:  node -e "console.log(crypto.randomBytes(32).toString('hex'))"
PROVIDER_KEY_ENC_SECRET=generate-a-long-random-secret

# ── Sync smoke test (packages/db, optional) ──────────────────────────────────
# A throwaway beta user used by `npm run sync:smoke` to validate the
# Dexie⇄Supabase path end-to-end against the real project. Leave blank to skip.
TESSERA_TEST_EMAIL=
TESSERA_TEST_PASSWORD=
